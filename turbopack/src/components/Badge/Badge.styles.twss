.badge {
  @apply
  inline-flex
  items-center
  px-2
  py-0.5
  rounded-full
  text-xs
  font-medium
}

.badge--default {
  @apply
  bg-zinc-100
  text-zinc-800
}

.badge--success {
  @apply
  bg-green-100
  text-green-800
}

.badge--warning {
  @apply
  bg-yellow-100
  text-yellow-800
}

.badge--danger {
  @apply
  bg-red-100
  text-red-800
}
